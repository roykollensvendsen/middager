---
interface Ingrediens {
  navn: string;
  mengde?: string;
  enhet?: string;
  gruppe?: string;
  notat?: string;
}
interface Props {
  ingredienser: Ingrediens[];
}
const { ingredienser } = Astro.props;

const grupper = new Map<string, Ingrediens[]>();
for (const i of ingredienser) {
  const gruppe = i.gruppe ?? 'Annet';
  if (!grupper.has(gruppe)) grupper.set(gruppe, []);
  grupper.get(gruppe)!.push(i);
}
---

<section class="rounded-2xl border border-stone-200 bg-white p-6">
  <h2 class="font-serif text-2xl font-bold text-lam">Ingredienser</h2>
  <div class="mt-4 grid gap-6 sm:grid-cols-2">
    {
      Array.from(grupper.entries()).map(([gruppe, items]) => (
        <div>
          <h3 class="text-sm font-semibold uppercase tracking-wide text-stone-500">
            {gruppe}
          </h3>
          <ul class="mt-2 space-y-1.5 text-sm">
            {items.map((i) => (
              <li class="flex items-baseline gap-2">
                <span class="min-w-[5rem] font-medium text-stone-700">
                  {i.mengde}
                  {i.enhet ? ` ${i.enhet}` : ''}
                </span>
                <span>
                  {i.navn}
                  {i.notat && (
                    <span class="ml-1 text-xs text-stone-500">({i.notat})</span>
                  )}
                </span>
              </li>
            ))}
          </ul>
        </div>
      ))
    }
  </div>
</section>
