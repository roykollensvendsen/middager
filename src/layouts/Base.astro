---
interface Props {
  tittel: string;
  beskrivelse?: string;
}
const { tittel, beskrivelse } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="no">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={beskrivelse ?? 'Familiens digitale kokebok'} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{tittel}</title>
  </head>
  <body class="bg-krem min-h-screen font-sans text-stone-800 antialiased">
    <header class="border-b border-stone-200 bg-white/70 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
        <a href={base} class="font-serif text-2xl font-bold text-lam">Middager</a>
        <nav class="text-sm text-stone-600">
          <a href={base} class="hover:text-lam">Alle oppskrifter</a>
        </nav>
      </div>
    </header>
    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>
    <footer class="border-t border-stone-200 py-8 text-center text-xs text-stone-500">
      Familiens kokebok · laget med Astro · prissjekk hos
      <a
        class="underline hover:text-lam"
        href="https://kassal.app"
        target="_blank"
        rel="noopener noreferrer">Kassalapp</a
      >
    </footer>
  </body>
</html>

<style is:global>
  html {
    scroll-behavior: smooth;
  }
  .prose h2 {
    font-family: 'Fraunces', Georgia, serif;
    color: #7a3b2e;
  }
</style>
